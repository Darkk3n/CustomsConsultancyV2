---
interface IArrowContainerProps {
	text: string;
	icon?: string;
}
const { text, icon } = Astro.props;
---

<div
	class="clip-arrow flex items-center p-4 sm:p-6 pr-12 max-w-full sm:max-w-xl"
	style={{ backgroundColor: "#001129" }}
>
	<div class="shrink-0 mr-1 sm:mr-2">
		<img
			src={`/${icon}.webp`}
			alt="Element Icon"
			class="w-32 h-32 sm:w-32 sm:h-32 object-contain"
		/>
	</div>
	<div class="text-white">
		<h2
			class="text-lg sm:text-2xl font-bold leading-tight italic uppercase tracking-wide"
		>
			{text}
		</h2>
	</div>
</div>
