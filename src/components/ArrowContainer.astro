---
interface IArrowContainerProps {
	text: string;
	icon?: string;
}
const { text, icon } = Astro.props;
---

<div class="clip-arrow bg-[#051125] flex items-center p-4 pr-16 gap-8">
	<div class="shrink-0 w-24 md:w-28">
		<img
			src={`/${icon}.webp`}
			alt=""
			class="w-full h-auto block"
			loading="eager"
			decoding="async"
		/>
	</div>

	<h2 class="text-white font-bold text-lg md:text-xl uppercase leading-tight">
		{text}
	</h2>
</div>

<style>
	.clip-arrow {
		/* The 40px here defines the depth of the arrow point */
		clip-path: polygon(
			0 0,
			calc(100% - 40px) 0,
			100% 50%,
			calc(100% - 40px) 100%,
			0 100%
		);
	}
</style>
