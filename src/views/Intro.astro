---
import SectionContainer from "@/components/SectionContainer.astro";
import { Image } from "astro:assets";
---

<SectionContainer split className="items-center text-white">
	<section class="w-full md:w-1/2 space-y-3">
		<p class="text-2xl sm:text-3xl md:text-5xl font-bold">
			JURÍDICO ADUANERO AGS
		</p>

		<p class="text-sm sm:text-base md:text-2xl text-justify">
			Es un Despacho Jurídico que ofrece servicios de Asesoría y Defensa Legal
			en Materia Aduanera y de Comercio Exterior.
		</p>
	</section>

	<section class="w-full md:w-1/2 flex justify-center">
		<Image
			src="/Services4.webp"
			alt="introduccion"
			width="600"
			height="400"
			class="rounded-lg shadow-xl"
		/>
	</section>
</SectionContainer>
